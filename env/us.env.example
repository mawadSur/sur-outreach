# Sur Consulting — OpenOutreach US stack env
# Copy to us.env and fill in. NEVER commit the real us.env (see outreach/.gitignore).
#
# LLM (one model drives qualification + follow-up agent + search-keyword generation).
# Anthropic via OpenAI-compatible endpoint, OR point LLM_API_BASE at your gateway.
LLM_API_KEY=sk-REPLACE_ME
AI_MODEL=claude-sonnet-4-6
# For Anthropic's native API, use the Anthropic base; for an OpenAI-compatible proxy, set that URL.
# Leave blank to use the provider default baked into the tool.
LLM_API_BASE=https://api.anthropic.com/v1/

# --- Timezone (matters) ------------------------------------------------------
# Set to the US IANA zone the account actually operates in. Drives BOTH the daemon's 9am-7pm
# active-hours window AND the browser's reported timezone (else it defaults to the image's UTC,
# a subtle mismatch for a US account). Examples: America/New_York, America/Chicago, America/Los_Angeles.
TZ=America/New_York

# --- Egress / proxy ----------------------------------------------------------
# 🔴 NO PROXY. OpenOutreach does NOT read HTTP_PROXY/HTTPS_PROXY (verified in source) — setting them
# does nothing. The container egresses via the host network. Run this on a US connection so the account
# (US-established) keeps egressing from a US IP. Do NOT add proxy vars here; they are dead config.

# Host file ownership (container runs as uid 1000). Set to your host uid/gid if not 1000.
HOST_UID=1000
HOST_GID=1000

# NOTE: LinkedIn credentials, the session cookie_data, daily limits, subscribe_newsletter, and campaign
# text are NOT set here — they live in the LinkedInProfile + Campaign Django models, entered during
# first-run onboarding or via Django Admin. The SAFE way to attach this account is to paste its Playwright
# storage_state JSON into LinkedInProfile.cookie_data in Django Admin BEFORE first browser launch, so the
# daemon never types the password. See ops/phase0-checklist.md §1 and §4.
